{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "webiqApiKey": {
      "value": "${WEBIQ_API_KEY}"
    },
    "customDomain": {
      "value": "${WEBIQ_CUSTOM_DOMAIN}"
    },
    "bindCertificate": {
      "value": "${WEBIQ_BIND_CERT}"
    },
    "minReplicas": {
      "value": "${WEBIQ_MIN_REPLICAS}"
    },
    "monthlyBudgetAmount": {
      "value": "${WEBIQ_MONTHLY_BUDGET}"
    }
  }
}
