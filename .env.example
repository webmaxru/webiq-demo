# Web IQ API key (required). Get one at https://aka.ms/WebIQ
WEBIQ_API_KEY=

# Backend server port (default: 3001)
PORT=3001

# Allowed browser origin for CORS in development (the Vite dev server)
WEB_ORIGIN=http://localhost:5173

# Per-request timeout for SDK calls in milliseconds (default: 15000)
WEBIQ_TIMEOUT_MS=15000

# --- Telemetry (Azure Application Insights) ---
# Optional locally. In Azure it is injected from the App Insights resource as a
# Container App secret. Leave blank to run with telemetry disabled (no-op).
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Optional salt for the anonymised visitor id used in engagement stats. Change to
# rotate the hash. Defaults to a built-in value when unset.
WEBIQ_ANON_SALT=

# --- Abuse protection (all optional; sensible defaults shown) ---

# Max length (characters) of the primary search input before it is rejected and
# recorded as an abuse signal (default: 2048)
WEBIQ_MAX_INPUT_LENGTH=2048

# Per-IP rate limiting (fixed window). Window in ms, plus max requests per window
# for the expensive /api/search endpoints and for the rest of the API.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_SEARCH_MAX=15
RATE_LIMIT_GENERAL_MAX=100

# Reverse-proxy hops to trust for X-Forwarded-For client IPs. Container Apps
# ingress = 1. Use 0 for direct/local (no proxy). (default: 1)
TRUST_PROXY_HOPS=1

# NOTE: the abuse alert needs no configuration. It is always provisioned and
# notifies the subscription's Owner role (the email registered on the Azure
# account that owns the subscription) — see docs/abuse-protection.md.

